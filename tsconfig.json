{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "com.tokensaver.dashboard.sdPlugin/bin",
    "sourceMap": true,
    "noEmitOnError": false
  },
  "include": ["src/**/*.ts"]
}
